#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path


PROJECT_ROOT = Path(__file__).resolve().parent
VENV_PYTHON = PROJECT_ROOT / ".venv" / "bin" / "python"


def ensure_project_python():
    if VENV_PYTHON.exists() and Path(sys.executable).resolve() != VENV_PYTHON.resolve():
        os.execv(str(VENV_PYTHON), [str(VENV_PYTHON), __file__, *sys.argv[1:]])


def run(command):
    return subprocess.call([sys.executable, "manage.py", *command])


def main():
    ensure_project_python()
    os.environ.setdefault("DJANGO_SETTINGS_MODULE", "report_forge.settings")

    migrate_status = run(["migrate"])
    if migrate_status != 0:
        return migrate_status

    return run(["runserver", "127.0.0.1:8000"])


if __name__ == "__main__":
    raise SystemExit(main())
